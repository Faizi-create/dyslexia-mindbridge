{
  "expo": {
    "name": "Dyslexia MindBridge",
    "slug": "dyslexia-mindbridge",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "dyslexiamindbridge",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dyslexiamindbridge.app"
    },
    "android": {
      "package": "com.dyslexiamindbridge.app",
      "adaptiveIcon": {
        "backgroundColor": "#FFF8E7"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-asset"
    ],
    "extra": {}
  }
}
